# App
APP_NAME=AI Workspace API
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=change-me-to-a-long-random-string-please-do-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Database (async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_workspace
# Sync URL used by Alembic
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_workspace

# Redis
REDIS_URL=redis://localhost:6379/0

# Default AI provider — 'auto' picks the first one with an API key configured below.
# Options: auto | openai | anthropic | gemini | mock
AI_PROVIDER=auto

# OpenAI (or any OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Legacy single-provider fallback (still honored)
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# CORS
CORS_ORIGINS=*

# Frontend (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/integrations/github/callback
GITHUB_SCOPES=read:user user:email repo

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback
GOOGLE_SCOPES=openid email profile

# Deployments
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
RAILWAY_API_TOKEN=
